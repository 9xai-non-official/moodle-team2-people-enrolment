# Copy to backend/.env (gitignored) and fill in the rotated password.
#
# Secrets are NOT distributed in the repo. TEAM_CREDENTIALS.md was committed
# once and is still recoverable from git history, so every value it held must
# be treated as compromised and rotated (T2-SEC-001 / D-SEC). Get the current
# password from the team secret store, not from a file in this tree.
#
# Session pooler (port 5432) — works with asyncpg.
DATABASE_URL=postgresql://postgres.<PROJECT-REF>:<PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres

# SUPABASE_URL / SUPABASE_SERVICE_KEY are no longer used: app/supa.py (the
# PostgREST layer that ran with the RLS-bypassing service_role key) is retired.
# The asyncpg pool in app/db.py is the single data layer.

# ── local dev auth — REQUIRED to sign in locally ──────────────────────────
# The SPA authenticates by minting a Bearer token from
# POST /api/permissions/dev-login. That endpoint 404s unless BOTH vars below
# are set (app/routers/permissions.py:32), so a production deploy that sets
# neither never exposes a credential mint.
#
# Without these, the app loads but every persona button fails with a 404 on
# dev-login and every gated request is then 401. Nothing else explains it, and
# the symptom looks like a broken frontend rather than missing config.
#
# AUTH_SECRET signs the token (app/services/auth.py). Any long random string
# works locally — generate your own, do NOT copy a teammate's:
#     python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Leave both UNSET in production.
AUTH_DEV_LOGIN=1
AUTH_SECRET=
