# ── WhoCan (the LMS) integration ─────────────────────────────────────────────
WHOCAN_API_URL=http://localhost:8010
# dry  = record what we WOULD send, touch nothing   (safe default)
# live = actually POST enrolment events to WhoCan
# off  = don't sync at all
WHOCAN_SYNC_MODE=dry
# The WhoCan user id the SIS acts as when enrolling (an admin → bypasses caps).
# 6 = "Amal Admin" in the demo data.
WHOCAN_SERVICE_USER=6

# ── Microsoft provisioning (Issa's service) — not wired yet ───────────────────
PROVISION_URL=
PROVISION_MODE=off

# ── SIS local storage ────────────────────────────────────────────────────────
SIS_DB_PATH=sis.db
