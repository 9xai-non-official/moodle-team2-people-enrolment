# Team 2 app — environment template. COPY to `.env` (gitignored) and fill in real values.
# Get real values from a teammate via a PRIVATE channel (Slack/WhatsApp DM). Never commit them.

# Supabase Postgres (FastAPI / asyncpg / psql) — transaction pooler on :6543
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Supabase API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # backend only — bypasses RLS, keep secret
SUPABASE_ANON_KEY=your-anon-key
