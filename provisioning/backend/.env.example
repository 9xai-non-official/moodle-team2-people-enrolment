# ── Microsoft Entra app registration (from Issa's tenant setup) ──────────────
# tenant_id / client_id are identifiers; CLIENT_SECRET is a SECRET — this file
# stays an example, the real values go in .env (gitignored). Never in git or
# chat (we already rotated one leaked key this month — not again).
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# The real licensed user who owns every course team — app-only team creation
# requires at least one owner (Graph constraint Issa's checklist names).
OWNER_UPN=

# dry  = no Graph calls; log exactly what WOULD happen  (safe default)
# live = call Microsoft Graph for real
PROVISION_MODE=dry

# Country code stamped on auto-created users (required before licensing)
TENANT_USAGE_LOCATION=JO

# Where the course→team map lives
PROV_DB_PATH=provision.db
